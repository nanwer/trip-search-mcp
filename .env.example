# Optional: only required for the `search_hotels` tool.
# Flights tools (`search_flights`, `search_cheapest_dates`) work without
# any API keys. Hotels go through SerpAPI's google_hotels endpoint:
#   - Sign up at https://serpapi.com  (free tier: 100 searches/month)
#   - Copy the key from https://serpapi.com/manage-api-key
#   - Uncomment the line below
# SERPAPI_KEY=your-serpapi-key-here

# Optional logging / caching knobs (defaults are usually fine):
# LOG_FILE_PATH=/absolute/path/to/log.jsonl     # default ~/.flights-mcp/logs/flight-search.log
# LOG_LEVEL=INFO
# CACHE_TTL_SECONDS=300
